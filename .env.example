# ── ElevenLabs Speech-to-Text (required for transcription) ────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2

# ── Google Gemini (required for body-language analysis) ───────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview

# ── Minimax LLM (required for teacher feedback generation) ────────────────────
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_BASE_URL=https://api.minimax.io/anthropic

# ── AWS S3 (optional; for large file uploads when deployed on Lambda) ───────
AWS_REGION=us-east-1
S3_UPLOAD_BUCKET=

# ── Misc ─────────────────────────────────────────────────────────────────────
FLUCTUATION_WINDOW_SECONDS=180
MAX_UPLOAD_BYTES=524288000   # 500 MB
DATABASE_PATH=/tmp/hte_anontokyo.db

# ── Direct S3 upload for large files (recommended for >100MB) ───────────────
S3_UPLOAD_BUCKET=
S3_UPLOAD_REGION=us-east-1
S3_UPLOAD_PREFIX=uploads
S3_PRESIGN_EXPIRES_SECONDS=3600
